Panels:
  - Class: rviz_common/Displays
    Name: Displays
  - Class: rviz_common/Views
    Name: Views
Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 0.65
      Class: rviz_default_plugins/Map
      Color Scheme: map
      Draw Behind: true
      Enabled: true
      Name: TestMap
      Topic:
        Depth: 1
        Durability Policy: Transient Local
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /local_avoidance_manual_test/test_map
      Use Timestamp: false
      Value: true
    - Alpha: 0.45
      Cell Size: 0.5
      Class: rviz_default_plugins/Grid
      Color: 160; 160; 164
      Enabled: true
      Line Style:
        Line Width: 0.03
        Value: Lines
      Name: Grid
      Plane: XY
      Plane Cell Count: 16
      Reference Frame: map
      Value: true
    - Class: rviz_default_plugins/Path
      Alpha: 0.85
      Buffer Length: 1
      Color: 120; 120; 120
      Enabled: true
      Line Style: Lines
      Line Width: 0.04
      Name: ReferencePath
      Offset:
        X: 0
        Y: 0
        Z: 0.02
      Pose Style: None
      Topic:
        Depth: 1
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /local_avoidance_manual_test/reference_path
      Value: true
    - Class: rviz_default_plugins/Path
      Alpha: 1
      Buffer Length: 1
      Color: 255; 180; 0
      Enabled: true
      Line Style: Lines
      Line Width: 0.07
      Name: AStarPath
      Offset:
        X: 0
        Y: 0
        Z: 0.06
      Pose Style: None
      Topic:
        Depth: 1
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /local_avoidance_manual_test/astar_path
      Value: true
    - Class: rviz_default_plugins/Path
      Alpha: 1
      Buffer Length: 1
      Color: 20; 180; 255
      Enabled: true
      Line Style: Lines
      Line Width: 0.06
      Name: OptimizedPath
      Offset:
        X: 0
        Y: 0
        Z: 0.1
      Pose Style: None
      Topic:
        Depth: 1
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /local_avoidance_manual_test/optimized_path
      Value: true
    - Class: rviz_default_plugins/Path
      Alpha: 1
      Buffer Length: 1
      Color: 40; 230; 90
      Enabled: true
      Line Style: Lines
      Line Width: 0.1
      Name: TrackingPath
      Offset:
        X: 0
        Y: 0
        Z: 0.14
      Pose Style: None
      Topic:
        Depth: 1
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /local_avoidance_manual_test/tracking_path
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: ManualObstacles
      Topic:
        Depth: 1
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /local_avoidance_manual_test/manual_obstacle_markers
      Value: true
    - Class: rviz_default_plugins/Marker
      Enabled: true
      Name: TestCostmapObstacles
      Topic:
        Depth: 1
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /local_avoidance_manual_test/test_costmap_obstacles
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: StartGoal
      Topic:
        Depth: 1
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /local_avoidance_manual_test/start_goal_markers
      Value: true
  Enabled: true
  Global Options:
    Background Color: 38; 38; 38
    Fixed Frame: map
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz_default_plugins/Interact
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Select
    - Class: rviz_default_plugins/SetInitialPose
      Topic: /initialpose
    - Class: rviz_default_plugins/SetGoal
      Topic: /goal_pose
    - Class: rviz_default_plugins/PublishPoint
      Single click: true
      Topic: /clicked_point
  Transformation:
    Current:
      Class: rviz_default_plugins/TF
  Value: true
  Views:
    Current:
      Class: rviz_default_plugins/Orbit
      Distance: 7
      Focal Point:
        X: 0
        Y: 0
        Z: 0
      Pitch: 1.5707
      Yaw: 0
Window Geometry:
  Height: 900
  Width: 1200

<?xml version="1.0"?>
<!--
  Gazebo 模型清单文件。
  Gazebo 通过 model.config 识别一个目录是否是可加载模型，并找到真正的 model.sdf。
-->
<model>
  <!-- 模型名需要和 world 文件中的 model://5m_map_arena 对应。 -->
  <name>5m_map_arena</name>
  <!-- 模型版本号，主要用于资源管理和人工识别。 -->
  <version>1.0</version>
  <!-- 指定 SDF 文件及其语法版本。 -->
  <sdf version="1.6">model.sdf</sdf>
  <author>
    <name>xjl</name>
  </author>
  <!-- 简短说明：5m x 5m 地面、0.5m 高围墙，以及智能车地图纹理。 -->
  <description>5m x 5m arena with 0.5m walls and smart-car map texture.</description>
</model>

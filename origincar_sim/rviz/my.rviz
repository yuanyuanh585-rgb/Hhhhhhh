Panels:
  - Class: rviz_common/Displays
    Help Height: 70
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Path1
        - /Path1/Offset1
        - /Path2
        - /Path2/Offset1
        - /Path3
        - /Path3/Offset1
        - /Map2
        - /Map2/Orientation1
      Splitter Ratio: 0.5
    Tree Height: 1026
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
